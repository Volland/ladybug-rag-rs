        subgraph "Community Detection (41 algorithms)"
            LV[Louvain / PLM]
            LD[Leiden]
            LP[Label Propagation]
            LF[LFM Overlapping]
        end

        subgraph "Distance & Paths"
            BFS[BFS]
            DIJ[Dijkstra]
            APSP[All-Pairs SP]
            AST[A*]
        end

        subgraph "Structure"
            CC[Connected Components]
            SP[Sparsification]
            MT[Matching]
        end
    end

    subgraph "Used in Hybrid RAG"
        RAG_PR["PageRank → Entity Importance"]
        RAG_LV["Louvain → Topic Clusters"]
        RAG_BFS["BFS → Graph Expansion"]
    end

    PR --> RAG_PR
    LV --> RAG_LV
    BFS --> RAG_BFS

